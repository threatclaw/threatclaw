{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threatclaw.io/schemas/grounding-benchmark-v1.0.json",
  "type": "object",
  "required": ["name", "description", "dossier", "llm_output", "expected"],
  "properties": {
    "name": { "type": "string", "minLength": 3 },
    "description": { "type": "string" },
    "dossier": {
      "type": "object",
      "required": ["global_score", "ml_anomaly_score", "sigma_alert_ids", "finding_ids", "kev_cves"],
      "properties": {
        "global_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "ml_anomaly_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "sigma_alert_ids": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "level"],
            "properties": {
              "id": { "type": "integer" },
              "level": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
            }
          }
        },
        "finding_ids": { "type": "array", "items": { "type": "integer" } },
        "kev_cves": { "type": "array", "items": { "type": "string" } }
      }
    },
    "llm_output": {
      "type": "object",
      "required": ["verdict", "severity", "confidence"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["confirmed", "false_positive", "inconclusive", "informational"]
        },
        "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "mitre_techniques": { "type": "array", "items": { "type": "string" } },
        "cves": { "type": "array", "items": { "type": "string" } },
        "evidence_citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim", "evidence_type", "evidence_id"],
            "properties": {
              "claim": { "type": "string" },
              "evidence_type": { "type": "string", "enum": ["alert", "finding", "log", "graph_node"] },
              "evidence_id": { "type": "string" }
            }
          }
        }
      }
    },
    "expected": {
      "type": "object",
      "required": ["mode", "final_verdict", "applied"],
      "properties": {
        "mode": { "type": "string", "enum": ["off", "lenient", "strict"] },
        "final_verdict": {
          "type": "string",
          "enum": ["confirmed", "false_positive", "inconclusive", "informational"]
        },
        "final_severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "rule_code": { "type": "string" },
        "applied": { "type": "boolean" }
      }
    }
  }
}
