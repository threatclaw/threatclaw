{
  "id": "skill-enrichment-crtsh",
  "name": "Certificate Transparency (crt.sh)",
  "version": "1.0.0",
  "description": "Surveille les certificats emis pour un domaine, detecte les sous-domaines et rogue certs",
  "author": "ThreatClaw",
  "trust": "official",
  "type": "enrichment",
  "category": "web-security",
  "execution": {
    "mode": "api",
    "base_url": "https://crt.sh/",
    "triggers": ["domain"],
    "cache_ttl_hours": 24
  },
  "config": {},
  "outputs": {
    "certificates": "graph"
  },
  "default_active": false,
  "requires_config": false,
  "api_key_required": false,
  "icon": "file-certificate"
}
