{
  "id": "skill-enrichment-phishtank",
  "name": "PhishTank",
  "version": "1.0.0",
  "description": "Verifie si une URL est connue comme phishing dans la base PhishTank",
  "author": "ThreatClaw",
  "trust": "official",
  "type": "enrichment",
  "category": "web-security",
  "execution": {
    "mode": "api",
    "base_url": "https://checkurl.phishtank.com/checkurl/",
    "triggers": ["domain", "url"],
    "cache_ttl_hours": 24
  },
  "config": {
    "phishtank_app_key": {
      "type": "password",
      "description": "PhishTank App Key (optional, higher rate limits)",
      "required": false
    }
  },
  "outputs": {
    "phishing_status": "graph"
  },
  "default_active": false,
  "requires_config": false,
  "api_key_required": false,
  "icon": "fish"
}
