{
  "id": "skill-trufflehog",
  "name": "TruffleHog Secrets Scanner",
  "version": "1.0.0",
  "description": "Detection de secrets, cles API, tokens dans le code source et les repositories Git.",
  "author": "ThreatClaw",
  "trust": "official",
  "type": "tool",
  "category": "appsec",
  "execution": {
    "mode": "ephemeral",
    "docker_image": "trufflesecurity/trufflehog:latest",
    "command": "trufflehog filesystem {TARGET} --json",
    "timeout_seconds": 300,
    "network": "none",
    "memory_limit": "512m"
  },
  "config": {
    "target_path": {
      "type": "string",
      "description": "Chemin du depot Git ou repertoire a scanner",
      "required": true
    }
  },
  "outputs": {
    "findings": "db"
  },
  "default_active": false,
  "requires_config": true,
  "api_key_required": false,
  "icon": "key"
}
