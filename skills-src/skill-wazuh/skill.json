{
  "id": "skill-wazuh",
  "name": "Connexion Wazuh",
  "version": "1.0.0",
  "description": "Import alertes depuis Wazuh SIEM — synchronisation bidirectionnelle",
  "author": "ThreatClaw",
  "trust": "official",
  "category": "monitoring",
  "runtime": "wasm",
  "docker_deps": {},
  "requires_network": true,
  "timeout_seconds": 120,
  "memory_mb": 32,
  "api_key_required": true,
  "secrets": [
    "wazuh_api_user",
    "wazuh_api_password"
  ],
  "capabilities": {
    "http_allowed": true,
    "workspace_read": false
  },
  "type": "connector",
  "requires_config": true,
  "default_active": false,
  "config": {
    "url": {
      "type": "string",
      "description": "URL API Wazuh (ex: https://wazuh:55000)",
      "required": true
    },
    "api_user": {
      "type": "string",
      "description": "Utilisateur API Wazuh",
      "required": true
    },
    "api_password": {
      "type": "password",
      "description": "Mot de passe API Wazuh",
      "required": true
    }
  }
}