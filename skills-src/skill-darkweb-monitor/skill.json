{
  "id": "skill-darkweb-monitor",
  "name": "Dark Web Monitor",
  "version": "1.0.0",
  "description": "Surveillance dark web — detection de fuites de donnees, credentials, mentions",
  "author": "ThreatClaw",
  "trust": "official",
  "category": "monitoring",
  "runtime": "wasm",
  "type": "tool",
  "requires_config": true,
  "default_active": false,
  "config": {
    "company_name": {
      "type": "string",
      "description": "Nom de l'entreprise a surveiller",
      "required": true
    },
    "domains": {
      "type": "string",
      "description": "Domaines a surveiller (separes par virgule)",
      "required": true
    },
    "email_patterns": {
      "type": "string",
      "description": "Patterns email (ex: *@monentreprise.fr)",
      "required": false
    }
  }
}