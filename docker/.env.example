# ============================================================
# ThreatClaw v2.0 — Environment Variables (.env)
# Copy this file to .env and customize.
# ============================================================

# ── Database ──────────────────────────────────────────────
TC_DB_PASSWORD=changeme-use-a-strong-password

# ── Instance Configuration ────────────────────────────────
TC_INSTANCE_NAME=threatclaw-prod

# Permission level: ALERT_ONLY (default) | SUGGEST | AUTO_FIX
TC_PERMISSION_LEVEL=ALERT_ONLY

# ── Ports (change if conflicts) ──────────────────────────
TC_CORE_PORT=3000
TC_DASHBOARD_PORT=3001
TC_SYSLOG_PORT=514

# ── Auth Token (auto-generated if empty) ─────────────────
# Leave blank for auto-generation on first start.
# Set to a fixed value for stable token across restarts.
TC_AUTH_TOKEN=

# ── LLM Configuration ────────────────────────────────────
# Local LLM model (via Ollama). Default: qwen3:8b
TC_L1_BASE_MODEL=qwen3:8b
# Auto-pull models on first start (true/false)
TC_AUTO_PULL_MODELS=true

# ── Cloud LLM (optional — for L2 escalation) ─────────────
# Leave blank to stay 100% local.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# ── Notifications (optional) ─────────────────────────────
SLACK_WEBHOOK_URL=

# ── GPU Support ──────────────────────────────────────────
# If you have an NVIDIA GPU, Ollama will use it automatically.
# No extra config needed — Docker detects nvidia runtime.
# For CPU-only: the compose file works without changes,
# the GPU reservation is optional.
