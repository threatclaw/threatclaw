# ============================================================
# ThreatClaw — Environment Variables (.env)
# Copy this file to .env and fill in the values.
# ============================================================

# ── Database ────────────────────────────────────────────────
# Password for the PostgreSQL database. Change this in production.
TC_DB_PASSWORD=changeme-use-a-strong-password

# ── Instance Configuration ──────────────────────────────────
# Human-readable name for this ThreatClaw instance.
TC_INSTANCE_NAME=threatclaw-prod

# Permission level controls what automated actions the core is
# allowed to take. One of:
#   ALERT_ONLY   — generate alerts, never act (default)
#   SUGGEST      — suggest remediations, require approval
#   AUTO_FIX     — automatically apply safe remediations
TC_PERMISSION_LEVEL=ALERT_ONLY

# ── Notifications (optional) ───────────────────────────────
# Slack incoming webhook URL for alert delivery.
# Leave blank to disable Slack notifications.
SLACK_WEBHOOK_URL=

# ── AI / LLM Keys (optional) ───────────────────────────────
# Provide ONE of the following for AI-assisted analysis.
# Leave both blank to disable LLM features.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
